# Admin panel password (required for /admin login)
# Local: copy to .env.local → ADMIN_PASSWORD=admin123
# Vercel: Settings → Environment Variables → ADMIN_PASSWORD=admin123 → Redeploy
ADMIN_PASSWORD=admin123

# Optional: sends inquiry emails via Resend (inquiries always saved to data/inquiries.jsonl)
RESEND_API_KEY=re_xxxxxxxx

# Where booking inquiries are delivered
CONTACT_TO_EMAIL=hello@greatsilktrails.com

# Sender address (must be verified in Resend)
CONTACT_FROM_EMAIL=GREATSILKTRAILS <hello@greatsilktrails.com>