# Public site URL (required for sitemap, canonical, Open Graph)
# Production example: https://greatsilktrails.com  or  https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=https://greatsilktrails.com

# Optional: Google Search Console / Yandex / Bing verification meta tags
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=paste_token_from_search_console
# NEXT_PUBLIC_YANDEX_VERIFICATION=
# NEXT_PUBLIC_BING_VERIFICATION=

# Admin panel password (required for /admin login)
# Local: copy to .env.local → ADMIN_PASSWORD=admin123
# Vercel: Settings → Environment Variables → ADMIN_PASSWORD=admin123 → Redeploy
ADMIN_PASSWORD=admin123

# Vercel Blob (recommended on production — image uploads + saving tours)
# Vercel Dashboard → Storage → Blob → Create Store → Connect to Project → Redeploy
BLOB_READ_WRITE_TOKEN=

# Alternative CMS storage on Vercel (if Blob not set) — saves tours.json to GitHub
# Create PAT with repo Contents write → add both vars → Redeploy
GITHUB_TOKEN=
GITHUB_REPO=rolimzod16-dotcom/AKUNASILK

# Optional: sends inquiry emails via Resend (inquiries always saved to data/inquiries.jsonl)
RESEND_API_KEY=re_xxxxxxxx

# Where booking inquiries are delivered
CONTACT_TO_EMAIL=hello@greatsilktrails.com

# Sender address (must be verified in Resend)
CONTACT_FROM_EMAIL=GREATSILKTRAILS <hello@greatsilktrails.com>

# --- Telegram bot: notify who sent Reserve / Plan enquiry ---
# 1) Create bot via @BotFather → copy token
# 2) Write /start to the bot from your personal Telegram
# 3) Get your chat id via @userinfobot or https://api.telegram.org/bot<TOKEN>/getUpdates
# 4) On Vercel: Settings → Environment Variables → add both → Redeploy
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: several managers (comma-separated)
# TELEGRAM_CHAT_IDS=123456789,987654321